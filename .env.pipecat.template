# Pipecat runtime configuration template

# Speech-to-Text
DEEPGRAM_API_KEY=
PIPECAT_STT_END_OF_SPEECH_WAIT_S=0.35

# LLM service (Megakernel FastAPI server)
LLM_SERVICE_URL=http://localhost:8000
PIPECAT_MAX_TOKENS=120
PIPECAT_MAX_HISTORY_TURNS=6
PIPECAT_MAX_ASSISTANT_HISTORY_TURNS=0
PIPECAT_SYSTEM_PROMPT="You are a concise, helpful voice assistant for a take-home demo."
PIPECAT_WELCOME_MESSAGE="ready"

# Keep spoken replies short and stable for the local Qwen3-TTS talker path.
PIPECAT_RESPONSE_FIRST_SENTENCE_ONLY=1
PIPECAT_RESPONSE_MAX_CHARS=80
PIPECAT_RESPONSE_CLAUSE_SOFT_LIMIT=72

# TTS client transport tuning.
PIPECAT_TTS_HTTP_MAX_ATTEMPTS=3
PIPECAT_TTS_HTTP_READ_CHUNK_BYTES=960
PIPECAT_TTS_API_MIN_NEW_TOKENS=48
PIPECAT_TTS_STRIP_LEADING_SILENCE=0
PIPECAT_TTS_LEADING_SILENCE_RMS=0.0015
PIPECAT_TTS_MAX_LEADING_SILENCE_BYTES=96000
PIPECAT_TTS_LOWERCASE_TEXT=1

# Warm the local TTS stack so the first real turn avoids the cold penalty.
TTS_PRELOAD_MODEL=1
TTS_WARMUP_ON_STARTUP=1
TTS_WARMUP_TEXT="ready"

# TTS runtime tuning: keep first-frame decode immediate, then back off to
# lower steady-state decode overhead without buffering the full utterance.
QWEN3_TTS_USE_INCREMENTAL_TOKENIZER_DECODER=1
QWEN3_TTS_REQUIRE_NON_SILENT_PREFIX=0
QWEN3_TTS_NON_SILENT_PEEK_CHUNKS=1
QWEN3_TTS_STRICT_NON_SILENT_PEEK_CHUNKS=12
QWEN3_TTS_MAX_PREFIX_SILENCE_S=0.8
QWEN3_TTS_STRICT_MAX_PREFIX_SILENCE_S=1.6
QWEN3_TTS_NON_SILENT_RMS=0.0005
QWEN3_TTS_ENABLE_SPEECH_STABILIZATION=1
QWEN3_TTS_NON_STREAMING_TEXT_MODE=1
QWEN3_TTS_DECODE_STRIDE_MID=12
QWEN3_TTS_DECODE_STRIDE_LATE=24
QWEN3_TTS_INCREMENTAL_LEFT_CONTEXT_FRAMES=12
QWEN3_TTS_SILENCE_EARLY_STOP=0
QWEN3_TTS_MIN_EOS_STEPS=6
QWEN3_TTS_MIN_EOS_STEPS_SHORT=2
QWEN3_TTS_MIN_FRAMES_BEFORE_REPEAT_STOP=32
QWEN3_TTS_REPEAT_FIRST_TOKEN_RUN_LIMIT=48
QWEN3_TTS_REPEAT_FRAME_RUN_LIMIT=12
QWEN3_TTS_MEDIUM_TEXT_CHAR_THRESHOLD=40
PIPECAT_TTS_MEDIUM_TEXT_CHAR_THRESHOLD=40

# Daily transport credentials.
# Option A: provide a pre-created room + token.
DAILY_ROOM_URL=
DAILY_ROOM_TOKEN=
DAILY_ROOM_NAME=

# Option B: provide an API key and let the demo create an ephemeral token.
DAILY_API_KEY=
DAILY_ROOM_TTL_SECONDS=3600
